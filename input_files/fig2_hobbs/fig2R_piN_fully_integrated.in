# arXiv:1411.2216 Fig 2 RIGHT -- F2^(pip)(x) fully integrated (purple dashed)
# pi0 exchange on proton target, no cuts
scan_mode      = kbin
output_name    = fig2R_piN_fullyintegrated
contribution   = pion
dissociation   = neutral
form_factor    = exp_s
lambda         = 1.56
nucleon        = proton
beam_energy    = 11.0
electron_angle = 35.0
x_min          = 0.05
x_max          = 0.30
nx             = 40
inclusive_mode = true
ny             = 100
nkt            = 5000
